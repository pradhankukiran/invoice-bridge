@page "/exports"
@attribute [Authorize(Policy = AuthorizationPolicies.ExportAccess)]
@rendermode InteractiveServer
@inject IAccountingExportService AccountingExportService

<PageTitle>Exports</PageTitle>

<h1>Accounting Exports</h1>
<p class="text-muted">Generate accounting payloads from approved invoices and move them to ReadyToPay.</p>

@if (!string.IsNullOrWhiteSpace(_statusMessage))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")" role="alert">@_statusMessage</div>
}

<div class="section-card mb-4">
    <div class="section-card-header">Generate Export</div>
    <div class="section-card-body">
        <div class="row g-3 mb-3">
            <div class="col-md-4">
                <label class="form-label">Generated By</label>
                <InputText class="form-control" @bind-Value="_generatedBy" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Format</label>
                <InputSelect class="form-select" @bind-Value="_format">
                    <option value="CSV">CSV</option>
                    <option value="XML">XML</option>
                </InputSelect>
            </div>
            <div class="col-md-5 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" @bind="_includeAllEligible" />
                    <label class="form-check-label">Include all approved invoices</label>
                </div>
            </div>
        </div>

        <button class="btn btn-primary me-2" @onclick="GenerateExportAsync" disabled="@_isGenerating">
            @(_isGenerating ? "Generating..." : "Generate Export")
        </button>
        <button class="btn btn-outline-secondary" @onclick="LoadAsync">Refresh Lists</button>
    </div>
</div>

<div class="section-card mb-4">
    <div class="section-card-header">Eligible Invoices (Approved)</div>
    <div class="section-card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th style="width: 40px;"></th>
                        <th>Invoice</th>
                        <th>Supplier</th>
                        <th>Due Date</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_eligibleInvoices.Count == 0)
                    {
                        <tr>
                            <td colspan="5">No approved invoices ready for export.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var invoice in _eligibleInvoices)
                        {
                            <tr>
                                <td>
                                    <input type="checkbox" class="form-check-input" checked="@_selectedInvoiceIds.Contains(invoice.InvoiceId)" disabled="@_includeAllEligible" @onchange="args => ToggleInvoice(invoice.InvoiceId, args.Value)" />
                                </td>
                                <td>@invoice.InvoiceNumber</td>
                                <td>@invoice.SupplierName</td>
                                <td>@(invoice.DueDate?.ToString("yyyy-MM-dd") ?? "-")</td>
                                <td>@invoice.TotalAmount.ToString("C")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="section-card mb-4">
    <div class="section-card-header">Export History</div>
    <div class="section-card-body">
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>Format</th>
                        <th>Status</th>
                        <th>Invoices</th>
                        <th>Total</th>
                        <th>Generated</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (_exports.Count == 0)
                    {
                        <tr>
                            <td colspan="7">No exports generated yet.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var export in _exports)
                        {
                            <tr>
                                <td>@export.ExportReference</td>
                                <td>@export.Format</td>
                                <td>@export.Status</td>
                                <td>@export.InvoiceCount</td>
                                <td>@export.TotalAmount.ToString("C")</td>
                                <td>@export.GeneratedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary me-2" href="@GetDownloadUrl(export.ExportId)">Download</a>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => LoadPayloadAsync(export.ExportId)">View Payload</button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(_payloadPreview))
{
    <div class="section-card">
        <div class="section-card-header">Payload Preview</div>
        <div class="section-card-body">
            <textarea class="form-control" rows="10" readonly>@_payloadPreview</textarea>
        </div>
    </div>
}

@code {
    private IReadOnlyList<ExportCandidateInvoiceDto> _eligibleInvoices = [];
    private IReadOnlyList<AccountingExportSummaryDto> _exports = [];
    private readonly HashSet<int> _selectedInvoiceIds = [];
    private string _generatedBy = "finance.officer";
    private string _format = "CSV";
    private bool _includeAllEligible = true;
    private bool _isGenerating;
    private bool _isError;
    private string? _statusMessage;
    private string? _payloadPreview;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _eligibleInvoices = await AccountingExportService.ListEligibleInvoicesAsync();
        _exports = await AccountingExportService.ListExportsAsync();

        if (_includeAllEligible)
        {
            _selectedInvoiceIds.Clear();
        }
    }

    private async Task GenerateExportAsync()
    {
        try
        {
            _isGenerating = true;

            var request = new CreateAccountingExportRequest
            {
                GeneratedBy = _generatedBy,
                Format = _format,
                IncludeAllEligible = _includeAllEligible,
                InvoiceIds = _selectedInvoiceIds.ToList()
            };

            var result = await AccountingExportService.CreateExportAsync(request);
            _payloadPreview = result.Payload;
            _isError = false;
            _statusMessage = $"Export {result.ExportReference} generated with {result.InvoiceCount} invoices.";

            _selectedInvoiceIds.Clear();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _isError = true;
            _statusMessage = ex.Message;
        }
        finally
        {
            _isGenerating = false;
        }
    }

    private async Task LoadPayloadAsync(int exportId)
    {
        _payloadPreview = await AccountingExportService.GetPayloadAsync(exportId);
    }

    private void ToggleInvoice(int invoiceId, object? value)
    {
        var isChecked = value is bool boolValue && boolValue;
        if (isChecked)
        {
            _selectedInvoiceIds.Add(invoiceId);
        }
        else
        {
            _selectedInvoiceIds.Remove(invoiceId);
        }
    }

    private static string GetDownloadUrl(int exportId)
    {
        return $"/api/exports/{exportId}/download";
    }
}
